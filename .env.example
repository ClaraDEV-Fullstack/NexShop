# =============================================================================
# NEXSHOP — Environment Variables
# Copy this file to .env (dev) or .env.production (prod) and fill in values.
# NEVER commit actual credentials to version control!
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================
DB_NAME=nexshop
DB_USER=nextshop_user
DB_PASSWORD=YourSecurePassword123!

# =============================================================================
# DJANGO
# =============================================================================
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-production-secret-key-here
DEBUG=False

# =============================================================================
# RENDER PRODUCTION (see .env.render.example for full copy-paste list)
# Frontend: https://nextshop-ui.onrender.com
# Backend:  https://nexshop-shur.onrender.com
# =============================================================================
# ALLOWED_HOSTS=nexshop-shur.onrender.com
# BACKEND_URL=https://nexshop-shur.onrender.com
# FRONTEND_URL=https://nextshop-ui.onrender.com
# CORS_ALLOWED_ORIGINS=https://nextshop-ui.onrender.com
# CSRF_TRUSTED_ORIGINS=https://nextshop-ui.onrender.com,https://nexshop-shur.onrender.com
# VITE_API_URL=https://nexshop-shur.onrender.com/api

# Your domain(s) — comma separated (local dev below)
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF trusted origins (with https://)
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# CORS allowed origins (with https://)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# URLS (used in emails + CinetPay callbacks)
# =============================================================================
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# =============================================================================
# FRONTEND
# =============================================================================
VITE_API_URL=http://127.0.0.1:8000/api

# =============================================================================
# CLOUDFLARE R2 — Image / Media Storage
# Images will always load even if you change your hosting provider.
#
# Setup:
#   1. Log in to Cloudflare → R2 → Create bucket (name = R2_BUCKET_NAME)
#   2. Enable "Public access" on the bucket → copy the public URL
#   3. Go to Manage R2 API Tokens → Create API token (Object Read & Write)
#   4. Copy Account ID from R2 dashboard overview
# =============================================================================
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=nexshop-media
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev

# =============================================================================
# PAYMENTS — mock (portfolio demo) or live (CinetPay)
#
# mock — simulates checkout locally, no gateway credentials needed
# live — requires CinetPay API key + site ID below
# =============================================================================
PAYMENT_MODE=mock

# =============================================================================
# CINETPAY — Payment Gateway (Visa/Mastercard + Orange Money + MTN MoMo)
#
# Setup:
#   1. Create merchant account at https://cinetpay.com
#   2. Dashboard → Settings → API Keys → copy APIKEY and SITE_ID
#   3. Set webhook URL in CinetPay dashboard to: https://yourdomain.com/api/payments/webhook/
#
# Currency: XOF (CFA Franc) | XAF | USD | EUR
# =============================================================================
CINETPAY_API_KEY=your-cinetpay-api-key
CINETPAY_SITE_ID=your-cinetpay-site-id
CINETPAY_CURRENCY=XOF

# =============================================================================
# EMAIL — Brevo (formerly Sendinblue) transactional email
# Free tier: 300 emails/day
#
# Setup: https://app.brevo.com → API Keys → create key
# =============================================================================
BREVO_API_KEY=your-brevo-api-key
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
DEFAULT_FROM_NAME=NEXSHOP

# Fallback SMTP (Gmail) — used if BREVO_API_KEY is not set
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# =============================================================================
# GOOGLE OAUTH
# =============================================================================
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# SENTRY — Error Tracking (optional but recommended)
# Free tier: 5,000 errors/month
#
# Setup: https://sentry.io → New Project → Django → copy DSN
# =============================================================================
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# =============================================================================
# PERFORMANCE
# =============================================================================
# Gunicorn: (2 × CPU cores) + 1 is the recommended formula
WEB_CONCURRENCY=3

# =============================================================================
# ADMIN ALERTS
# =============================================================================
# Email to notify when product stock drops below low_stock_threshold
# Configure in Django Admin → Site Settings after first deploy

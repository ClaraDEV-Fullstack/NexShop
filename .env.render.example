# =============================================================================
# RENDER PRODUCTION — copy these into the Render dashboard
# Frontend: NextShop_ui (Static Site) → https://nextshop-ui.onrender.com
# Backend:  NexShop (Web Service)     → https://nexshop-shur.onrender.com
# =============================================================================

# ─── FRONTEND (Static Site → Environment) ───────────────────────────────────
# Required at BUILD time — redeploy after changing any VITE_* variable.

VITE_API_URL=https://nexshop-shur.onrender.com/api
VITE_GOOGLE_CLIENT_ID=459725446333-b4b8ofqj8gltqqnhmik8ihshgf1nvddu.apps.googleusercontent.com
NODE_VERSION=20

# ─── BACKEND (Web Service → Environment) ────────────────────────────────────

ALLOWED_HOSTS=nexshop-shur.onrender.com
BACKEND_URL=https://nexshop-shur.onrender.com
FRONTEND_URL=https://nextshop-ui.onrender.com
CORS_ALLOWED_ORIGINS=https://nextshop-ui.onrender.com
CSRF_TRUSTED_ORIGINS=https://nextshop-ui.onrender.com,https://nexshop-shur.onrender.com

DEBUG=False
WEB_CONCURRENCY=1
PAYMENT_MODE=mock

# From Render PostgreSQL dashboard (Internal Database URL)
DATABASE_URL=postgresql://...

# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-production-secret-key

# Google OAuth (same client ID as frontend)
GOOGLE_OAUTH_CLIENT_ID=459725446333-b4b8ofqj8gltqqnhmik8ihshgf1nvddu.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Email — Brevo SMTP
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-brevo-smtp-login
EMAIL_HOST_PASSWORD=your-brevo-smtp-key
DEFAULT_FROM_EMAIL=your-verified-sender@email.com
DEFAULT_FROM_NAME=NEXSHOP

# Cloudflare R2 (optional — Supabase is used when configured below)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=nexshop-media
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# Supabase Storage — REQUIRED for product images on Render
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=media

# ─── GOOGLE CLOUD CONSOLE (OAuth client → Web application) ────────────────────
# This app uses Google Sign-In on the frontend (no backend redirect callback).
#
# Authorized JavaScript origins:
#   https://nextshop-ui.onrender.com
#   http://localhost:3000
#   http://localhost:5173
#
# Authorized redirect URIs:
#   https://nextshop-ui.onrender.com
#   http://localhost:3000
#   http://localhost:5173
#
# Backend API (frontend POSTs Google token here — not a Google Console redirect):
#   https://nexshop-shur.onrender.com/api/accounts/google/auth/
